<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.control.TabPane?>
<?import javafx.scene.control.Tab?>
<TabPane prefHeight="734.0" prefWidth="600.0" style="-fx-background-color: #333d34;" xmlns="http://javafx.com/javafx/23" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.employeeperformanceapp.HelloController">
   <tabs>
      <!-- Главный экран -->
      <Tab text="Home">
         <content>
            <VBox fx:id="mainScreen" alignment="CENTER" spacing="20" style="-fx-background-color: #333d34;">
               <Label style="-fx-font-size: 24px; -fx-font-weight: bold;" text="Welcome to Employee Management" textFill="WHITE" />
               <Button onAction="#loadEmployeeData" prefHeight="27.0" prefWidth="212.0" style="-fx-background-color: #4d0909; -fx-text-fill: white; -fx-font-size: 14px; -fx-padding: 10; -fx-border-radius: 50%; -fx-background-radius: 15;" text="Employee" />
               <Button onAction="#loadTrashData" prefHeight="41.0" prefWidth="122.0" style="-fx-background-color: #4d0909; -fx-text-fill: white; -fx-font-size: 14px; -fx-padding: 10; -fx-background-radius: 15;" text="Trash" />
            </VBox>
         </content>
      </Tab>

      <!-- Экран с сотрудниками -->
      <Tab text="Employees">
         <content>
            <VBox fx:id="employeeScreen" alignment="CENTER" spacing="20" style="-fx-background-color: #f4f4f9;">
               <Label style="-fx-font-size: 24px; -fx-font-weight: bold;" text="Employee Management" />

               <!-- Поля ввода данных -->
               <VBox alignment="CENTER_LEFT" spacing="10" style="-fx-padding: 20;">
                  <HBox spacing="10">
                     <Label text="FullName:" style="-fx-font-size: 14px;" />
                     <TextField fx:id="fullNameField" promptText="Enter full name" />
                  </HBox>
                  <HBox spacing="10">
                     <Label text="Department:" style="-fx-font-size: 14px;" />
                     <TextField fx:id="departmentField" promptText="Enter department" />
                  </HBox>
                  <Label text="Evaluation:" style="-fx-font-size: 18px;" />
                  <HBox spacing="10">
                     <Label text="Attendance:" style="-fx-font-size: 14px;" />
                     <TextField fx:id="attendanceField" promptText="Enter attendance score" />
                  </HBox>
                  <HBox spacing="10">
                     <Label text="Soft Skills:" style="-fx-font-size: 14px;" />
                     <TextField fx:id="softSkillsField" promptText="Enter soft skills score" />
                  </HBox>
                  <HBox spacing="10">
                     <Label text="Hard Skills:" style="-fx-font-size: 14px;" />
                     <TextField fx:id="hardSkillsField" promptText="Enter hard skills score" />
                  </HBox>
               </VBox>

               <!-- Кнопки -->
               <HBox alignment="CENTER" spacing="20">
                  <Button onAction="#addEmployee" style="-fx-background-color: #4CAF50; -fx-text-fill: white; -fx-font-size: 14px; -fx-padding: 10;" text="Save Employee" />
                  <Button onAction="#clearFields" style="-fx-background-color: #FF9800; -fx-text-fill: white; -fx-font-size: 14px; -fx-padding: 10;" text="Clear Fields" />
               </HBox>
            </VBox>
         </content>
      </Tab>

      <!-- Экран с корзиной -->
      <Tab text="Trash">
         <content>
            <VBox fx:id="trashScreen" alignment="CENTER" spacing="20" style="-fx-background-color: #f4f4f9;">
               <Label style="-fx-font-size: 24px; -fx-font-weight: bold;" text="Trash Management" />
               <TableView fx:id="trashTable" prefWidth="550.0">
                  <columns>
                     <TableColumn fx:id="trashNameColumn" text="Name" />
                     <TableColumn fx:id="trashDepartmentColumn" text="Department" />
                  </columns>
               </TableView>
               <HBox alignment="CENTER" spacing="20">
                  <Button onAction="#restoreEmployee" style="-fx-background-color: #4CAF50; -fx-text-fill: white; -fx-font-size: 14px; -fx-padding: 10;" text="Restore Employee" />
               </HBox>
            </VBox>
         </content>
      </Tab>
   </tabs>
</TabPane>
